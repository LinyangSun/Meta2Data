#!/bin/bash

show_help() {
    cat << EOF
Usage: Meta2Data <command> [options]

Available commands:
    MetaDL                  Search keywords combination in NCBI and CNCB. Download and preclean metadata.
    AmpliconPIP             Download and process amplicon sequencing data based on user provided metadata.
    AmpliconTAXA            Merge amplicon datasets (--asv | --otu) and assign taxonomy (GreenGenes2 or SILVA).
    ShortreadsPIP           TBD

Run 'Meta2Data <command> --help' for command-specific options.
EOF
}

if [[ $# -eq 0 ]]; then
    show_help
    exit 1
fi

COMMAND=$1
shift
case $COMMAND in
    MetaDL)
        Meta2Data-MetaDL "$@"
        ;;
    AmpliconPIP)
        Meta2Data-AmpliconPIP "$@"
        ;;
    AmpliconTAXA)
        Meta2Data-AmpliconTAXA "$@"
        ;;
    ShortreadsPIP)
        Meta2Data-ShortreadsPIP "$@"
        ;;
    -h|--help)
        show_help
        exit 0
        ;;
    *)
        echo "Error: Unknown command '$COMMAND'"
        show_help
        exit 1
        ;;
esac