#!/bin/bash
set -e

# Find scripts directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Search for scripts directory in multiple possible locations
find_scripts_dir() {
    local search_paths=(
        "${SCRIPT_DIR}/scripts"                          # Development/git repo
        "${SCRIPT_DIR}/share/Meta2Data/scripts"          # pip install --target
        "/usr/local/share/Meta2Data/scripts"             # System install
        "${HOME}/.local/share/Meta2Data/scripts"         # User install (pip install --user)
        "${CONDA_PREFIX}/share/Meta2Data/scripts"        # Conda install
        "${PREFIX}/share/Meta2Data/scripts"              # Alternative prefix
    )

    for path in "${search_paths[@]}"; do
        if [[ -d "$path" && -f "$path/taxonomy.sh" ]]; then
            echo "$path"
            return 0
        fi
    done

    echo "ERROR: Scripts directory not found in any location:" >&2
    for path in "${search_paths[@]}"; do
        echo "  - $path" >&2
    done
    return 1
}

if ! SCRIPTS=$(find_scripts_dir); then
    echo "ERROR: Cannot find scripts directory"
    exit 1
fi

show_help() {
    cat << EOF
Usage: Meta2Data AmpliconTAXA (--asv | --otu) [options]

Merge amplicon datasets, orient sequences against GreenGenes2, assign
taxonomy, and build a phylogenetic tree.

This command takes the output of AmpliconPIP (PRJ* folders containing
<id>-<mode>-final-table.qza and <id>-<mode>-final-rep-seqs.qza files) and,
depending on the mode, performs:

  --otu  (vsearch 97% OTUs)
    1. Merge feature tables and representative sequences
    2. Orient sequences against GreenGenes2 backbone (drop unmatched)
    3. Filter feature table to oriented sequences
    4. Taxonomy assignment via pre-trained Naive Bayes classifier (sklearn)
    5. Phylogenetic tree via SEPP fragment insertion (GG2 reference)
    6. Filter feature table AND representative sequences to tree-placed features

  --asv  (DADA2 single-base ASVs, single amplicon region assumed)
    1. Merge feature tables and representative sequences
    2. Orient sequences against GreenGenes2 backbone (drop unmatched)
    3. Filter feature table to oriented sequences
    4. Taxonomy assignment via pre-trained Naive Bayes classifier (sklearn)
    5. De novo phylogenetic tree (mafft + mask + fasttree)

Orientation always uses the GreenGenes2 backbone regardless of --db-type;
only taxonomy assignment depends on --db-type. SEPP tree building (otu) always
uses the GG2 reference. Re-running with a different --db-type reuses every
database-independent step and only recomputes the taxonomy artifact.

Mode is required and mutually exclusive: pass exactly one of --asv / --otu.
ASV and OTU outputs must not be mixed in one run (incompatible feature
definitions); each PRJ* folder is collected by its mode token.

Required options:
    --asv | --otu         Feature mode (mutually exclusive, required). Must match
                          the AmpliconPIP run that produced the input.
    --db DIR              Path to database directory (files are stored here;
                          use --dl to download them automatically)
    -i, --input DIR       Input directory containing PRJ* dataset folders
                          (output of a previous AmpliconPIP run)

Optional options:
    --db-type TYPE        Taxonomy database for classification. One of:
                            greengenes  - GreenGenes2 2024.09 (default)
                            silva       - SILVA 138.99
    -o, --output DIR      Output directory for merged results (default: same as --input)
    -t, --threads int     Number of CPU threads (default: 4)
    --confidence FLOAT    Confidence threshold for sklearn classifier (default: 0.7)
    --dl                  Download database files to --db directory before running
    -h, --help            Show this help message

Database files (downloaded with --dl):
    Always (used for orientation, regardless of --db-type):
      2024.09.backbone.full-length.fna.qza       (GG2 reference sequences)
    Per --db-type (used for taxonomy):
      greengenes: 2024.09.backbone.full-length.nb.qza   (GG2 NB classifier)
      silva:      silva-138-99-nb-classifier.qza         (SILVA NB classifier)
    --otu only (used for SEPP tree):
      sepp-refs-gg-13-8.qza                       (SEPP reference tree, GG2)

Example usage:
    # OTU mode, GreenGenes2 (default), auto-download
    Meta2Data AmpliconTAXA --otu --db /path/to/db --dl -i /path/to/output -t 8

    # ASV mode, SILVA classification
    Meta2Data AmpliconTAXA --asv --db /path/to/db --db-type silva --dl -i /path/to/output -t 8

Output structure (MODE = asv | otu; DB = gg2 | silva):
    <output_dir>/final-<MODE>/
    ├── ... final products (in main dir) ...
    │       otu: treeFilteredTable.qza, treeFilteredRepSeqs.qza, seppTree.qza
    │       asv: orientedTable.qza, orientedRepSeqs.qza, denovoRootedTree.qza
    │       both: <DB>Taxonomy.qza        (e.g. gg2Taxonomy.qza / silvaTaxonomy.qza)
    └── tmp/                              # intermediates + diagnostics (safe to delete)

EOF
}

# Default parameters
MODE=""
DB_DIR=""
DB_TYPE="greengenes"
ENABLE_DL=false
INPUT_DIR=""
OUTPUT=""
THREADS=4
CONFIDENCE=0.7

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --asv)
            if [[ -n "$MODE" && "$MODE" != "asv" ]]; then
                echo "Error: --asv and --otu are mutually exclusive"
                exit 1
            fi
            MODE="asv"
            shift
            ;;
        --otu)
            if [[ -n "$MODE" && "$MODE" != "otu" ]]; then
                echo "Error: --asv and --otu are mutually exclusive"
                exit 1
            fi
            MODE="otu"
            shift
            ;;
        --db)
            DB_DIR="$2"
            shift 2
            ;;
        --db-type)
            DB_TYPE="$2"
            shift 2
            ;;
        --dl)
            ENABLE_DL=true
            shift
            ;;
        --confidence)
            CONFIDENCE="$2"
            shift 2
            ;;
        -i|--input)
            INPUT_DIR="$2"
            shift 2
            ;;
        -o|--output)
            OUTPUT="$2"
            shift 2
            ;;
        -t|--threads)
            THREADS="$2"
            shift 2
            ;;
        -h|--help)
            show_help
            exit 0
            ;;
        *)
            echo "Error: Unknown option '$1'"
            show_help
            exit 1
            ;;
    esac
done

# Validate mode (required, mutually exclusive)
if [[ -z "$MODE" ]]; then
    echo "Error: feature mode is required - pass exactly one of --asv / --otu"
    show_help
    exit 1
fi

# Validate thread count is a positive integer
if ! [[ "$THREADS" =~ ^[1-9][0-9]*$ ]]; then
    echo "Error: --threads must be a positive integer, got '$THREADS'"
    exit 1
fi

# Validate --db-type
case "$DB_TYPE" in
    greengenes|silva) ;;
    *)
        echo "Error: --db-type must be one of: greengenes, silva (got '$DB_TYPE')"
        exit 1
        ;;
esac

# Validate --confidence is a valid float between 0 and 1
if ! [[ "$CONFIDENCE" =~ ^[0-9]*\.?[0-9]+$ ]] || \
   awk "BEGIN{exit !($CONFIDENCE < 0 || $CONFIDENCE > 1)}" 2>/dev/null; then
    echo "Error: --confidence must be a number between 0 and 1, got '$CONFIDENCE'"
    exit 1
fi

# Validate required parameters
if [[ -z "$DB_DIR" ]]; then
    echo "Error: --db is required"
    show_help
    exit 1
fi

if [[ -z "$INPUT_DIR" ]]; then
    echo "Error: --input is required"
    show_help
    exit 1
fi

# Strip trailing slashes from user-provided paths
DB_DIR="${DB_DIR%/}"
INPUT_DIR="${INPUT_DIR%/}"
OUTPUT="${OUTPUT%/}"

# Create DB_DIR if it doesn't exist (needed for --dl)
mkdir -p "$DB_DIR"
DB_DIR=$(cd "$DB_DIR" && pwd)

# Validate and convert INPUT_DIR to absolute path
if [[ ! -d "$INPUT_DIR" ]]; then
    echo "Error: Input directory '$INPUT_DIR' does not exist"
    echo "This should be the output directory from a previous AmpliconPIP run"
    exit 1
fi
INPUT_DIR=$(cd "$INPUT_DIR" && pwd)

# Default OUTPUT to INPUT_DIR if not specified
if [[ -z "$OUTPUT" ]]; then
    OUTPUT="$INPUT_DIR"
else
    mkdir -p "$OUTPUT"
    OUTPUT=$(cd "$OUTPUT" && pwd)
fi

# Database file names.
#   ORIENT_REF : reference sequences for orientation. Always the GG2 backbone,
#                regardless of --db-type (only taxonomy depends on --db-type).
#   NB_CLASSIFIER : pre-trained Naive Bayes classifier for --db-type.
#   SEPP_REF   : SEPP reference tree (GG2). Only needed for --otu.
ORIENT_REF="${DB_DIR}/2024.09.backbone.full-length.fna.qza"
SEPP_REF="${DB_DIR}/sepp-refs-gg-13-8.qza"

case "$DB_TYPE" in
    greengenes)
        DB_LABEL="gg2"
        NB_CLASSIFIER="${DB_DIR}/2024.09.backbone.full-length.nb.qza"
        ;;
    silva)
        DB_LABEL="silva"
        NB_CLASSIFIER="${DB_DIR}/silva-138-99-nb-classifier.qza"
        ;;
esac

################################################################################
#                    DOWNLOAD DATABASE (if --dl enabled)                        #
################################################################################

if [[ "$ENABLE_DL" == true ]]; then
    GG2_BASE="http://ftp.microbio.me/greengenes_release/2024.09/"
    SILVA_CLS="https://data.qiime2.org/classifiers/sklearn-1.4.2/silva/"
    SEPP_URL="https://data.qiime2.org/classifiers/sepp-ref-dbs/"

    echo "========================================="
    echo "Downloading Database Files"
    echo "Target:  $DB_DIR"
    echo "Mode:    $MODE"
    echo "DB type: $DB_TYPE ($DB_LABEL)"
    echo "========================================="
    echo ""

    # Validate a .qza file by checking it is a non-empty, valid zip archive
    validate_qza() {
        local file="$1"
        [[ -f "$file" ]] && [[ -s "$file" ]] && unzip -tq "$file" >/dev/null 2>&1
    }

    # Each entry: "filename|base_url|wget_extra_flags"
    DL_FILES=()
    # Orientation reference: always the GG2 backbone sequences
    DL_FILES+=("2024.09.backbone.full-length.fna.qza|${GG2_BASE}|--no-check-certificate")
    # Taxonomy classifier: per --db-type
    case "$DB_TYPE" in
        greengenes)
            DL_FILES+=("2024.09.backbone.full-length.nb.qza|${GG2_BASE}|--no-check-certificate")
            ;;
        silva)
            DL_FILES+=("silva-138-99-nb-classifier.qza|${SILVA_CLS}|")
            ;;
    esac
    # SEPP reference: only for --otu (--asv builds a de novo tree)
    if [[ "$MODE" == "otu" ]]; then
        DL_FILES+=("sepp-refs-gg-13-8.qza|${SEPP_URL}|")
    fi

    for entry in "${DL_FILES[@]}"; do
        IFS='|' read -r fname base_url extra_flags <<< "$entry"
        target="${DB_DIR}/${fname}"
        if validate_qza "$target"; then
            echo "Valid file exists: ${fname}, skipping download"
        else
            [[ -f "$target" ]] && echo "Existing file is corrupt or incomplete, re-downloading: ${fname}"
            rm -f "$target"
            echo "Downloading: ${fname}..."
            # shellcheck disable=SC2086
            if ! wget -q --show-progress ${extra_flags} -O "$target" "${base_url}${fname}"; then
                echo "ERROR: Failed to download ${fname}"
                rm -f "$target"
                exit 1
            fi
            if ! validate_qza "$target"; then
                echo "ERROR: Downloaded file is corrupt: ${fname}"
                rm -f "$target"
                exit 1
            fi
            echo "Downloaded and verified: ${fname}"
        fi
    done

    echo ""
    echo "Database download complete."
    echo ""
fi

################################################################################
#                    VALIDATE DATABASE FILES                                    #
################################################################################

echo "========================================="
echo "Validating Database Files"
echo "========================================="

# Mode-aware: orientation ref + classifier always; SEPP ref only for --otu.
NEEDED_FILES=("$ORIENT_REF" "$NB_CLASSIFIER")
if [[ "$MODE" == "otu" ]]; then
    NEEDED_FILES+=("$SEPP_REF")
fi

MISSING=false
for f in "${NEEDED_FILES[@]}"; do
    if [[ ! -f "$f" ]]; then
        echo "ERROR: Required file not found: $f"
        MISSING=true
    else
        echo "Found: $(basename "$f")"
    fi
done

if [[ "$MISSING" == true ]]; then
    echo ""
    echo "Use --dl to download missing database files automatically"
    exit 1
fi
echo ""

################################################################################
#                    DISPLAY CONFIGURATION                                     #
################################################################################

echo "========================================="
echo "Meta2Data AmpliconTAXA"
echo "========================================="
echo "Mode:           $MODE"
echo "Database Dir:   $DB_DIR"
echo "Database Type:  $DB_TYPE ($DB_LABEL)"
echo "  Orient Ref:   $(basename "$ORIENT_REF")  (GG2, always)"
echo "  Classifier:   $(basename "$NB_CLASSIFIER")"
if [[ "$MODE" == "otu" ]]; then
    echo "  SEPP Ref:     $(basename "$SEPP_REF")"
fi
echo "Confidence:     $CONFIDENCE"
echo "Input:          $INPUT_DIR"
echo "Output:         $OUTPUT"
echo "Threads:        $THREADS"
echo "========================================="
echo ""

################################################################################
#                    RUN TAXONOMY PIPELINE                                      #
################################################################################

# Export environment variables for taxonomy.sh
export MODE
export DB_LABEL
export NB_CLASSIFIER
export ORIENT_REF
export SEPP_REF
export CONFIDENCE
export INPUT_DIR
export OUTPUT
export cpu=$THREADS

# Redirect ALL temporary-file paths to the output directory so that the
# pipeline never touches the small /tmp on HPC compute nodes.
PIPELINE_TMPDIR="${OUTPUT}/.tmpdir"
mkdir -p "$PIPELINE_TMPDIR"
export TMPDIR="$PIPELINE_TMPDIR"
export TEMP="$PIPELINE_TMPDIR"
export TMP="$PIPELINE_TMPDIR"
export QIIME2_CACHE="${PIPELINE_TMPDIR}/qiime2-cache"
mkdir -p "$QIIME2_CACHE"
export PYTHONWARNINGS="ignore::FutureWarning"

echo "========================================="
echo "Running Taxonomy & Tree Pipeline"
echo "Started: $(date)"
echo "TMPDIR:         $TMPDIR"
echo "========================================="
echo ""

if ! bash "${SCRIPTS}/taxonomy.sh"; then
    echo "ERROR: Taxonomy pipeline failed"
    echo "Check logs in: $OUTPUT"
    echo "QIIME2 tmpdir preserved for debugging: $PIPELINE_TMPDIR"
    exit 1
fi

echo ""
echo "Taxonomy pipeline completed successfully"
echo ""

################################################################################
#                             Final Summary                                    #
################################################################################

echo "========================================="
echo "AmpliconTAXA COMPLETE"
echo "Finished: $(date)"
echo "========================================="
echo ""
echo "Results saved in: ${OUTPUT}/final-${MODE}/"
echo "========================================="
